# ── Investly — Environment Configuration ─────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# All keys must start with EXPO_PUBLIC_ to be readable in client-side JS.
#
# ── ASP.NET C# Backend (local development) ───────────────────────────────────
#
#   Default ASP.NET HTTPS port : 7000   (https://localhost:7000)
#   Default ASP.NET HTTP  port : 5000   (http://localhost:5000)
#
#   Android emulator cannot reach "localhost" on the host machine.
#   Use 10.0.2.2 instead of localhost when running on the Android emulator:
#     http://10.0.2.2:5000/api
#
#   iOS simulator CAN use localhost normally.
#   Physical device must use the host machine's LAN IP (e.g. 192.168.x.x).
#
# ── Required ──────────────────────────────────────────────────────────────────

# Set to false to use the real ASP.NET backend
EXPO_PUBLIC_USE_MOCK_API=false

# Your ASP.NET API base URL — the app appends endpoint paths to this
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api

# ── Examples ──────────────────────────────────────────────────────────────────
# iOS simulator (localhost):
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api
#
# Android emulator (10.0.2.2):
#   EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5000/api
#
# Physical device (your LAN IP):
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:5000/api
#
# Production (deployed):
#   EXPO_PUBLIC_API_BASE_URL=https://api.investly.ly/api
#
# HTTPS with self-signed cert (dev only — React Native allows this by default):
#   EXPO_PUBLIC_API_BASE_URL=https://localhost:7000/api
