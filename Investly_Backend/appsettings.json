{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Connection string for SQL Server database
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=InvestlyFullDb;User Id=sa;Password=YourPassword;TrustServerCertificate=True;"
  },

  // JWT (JSON Web Token) configuration
  // These settings control how tokens are created and validated
  "JWT": {
    // Secret key used to sign tokens (CHANGE THIS to a strong random key!)
    // Minimum 32 characters for security (256 bits for HMAC-SHA256)
    "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    // Who issued the token (usually your API URL)
    "Issuer": "InvestlyAPI",
    // Who the token is intended for (usually your frontend URL)
    "Audience": "InvestlyFrontend",
    // How long until the token expires (in minutes)
    "ExpireMinutes": "60"
  },

  // SMTP email configuration for sending emails (registration, notifications, etc.)
  "Email": {
    "FromEmail": "noreply@investly.com",
    "FromName": "Investly Platform",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password"
  }
}
